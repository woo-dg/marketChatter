generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Provider: KALSHI | POLYMARKET | X
// MarketStatus: OPEN | RESOLVED | CANCELLED | PAUSED
// StanceLabel: YES | NO | NEUTRAL
// JobStatus: PENDING | RUNNING | SUCCESS | FAILED

model Category {
  id          String               @id @default(cuid())
  slug        String               @unique
  name        String
  description String?
  icon        String?
  tagId       String?              @unique
  active      Boolean              @default(true)

  markets     Market[]
  sources     CategorySourceAccount[]

  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([active, slug])
}

model SourceAccount {
  id                 String                   @id @default(cuid())
  provider           String
  providerUserId     String
  handle             String
  displayName        String
  profileImageUrl    String?
  verified           Boolean                  @default(false)
  active             Boolean                  @default(true)
  trustScore         Float                    @default(0.5)
  priorityWeight     Float                    @default(1.0)
  latestSyncedPostId String?
  latestSyncedAt     DateTime?

  categories         CategorySourceAccount[]
  posts              Post[]

  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt

  @@unique([provider, providerUserId])
  @@index([active, provider])
  @@index([handle])
}

model CategorySourceAccount {
  id              String         @id @default(cuid())
  categoryId      String
  sourceAccountId String

  category        Category       @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  sourceAccount   SourceAccount  @relation(fields: [sourceAccountId], references: [id], onDelete: Cascade)

  @@unique([categoryId, sourceAccountId])
  @@index([categoryId])
  @@index([sourceAccountId])
}

model Market {
  id               String            @id @default(cuid())
  provider         String
  providerMarketId String
  providerEventId  String?
  providerEventSlug String?
  slug             String            @unique
  title            String
  subtitle         String?
  description      String?
  url              String?
  rulesUrl         String?

  categoryId       String?
  category         Category?         @relation(fields: [categoryId], references: [id])

  status           String            @default("OPEN")
  endDate          DateTime?
  resolvedOutcome  String?
  active           Boolean           @default(true)

  outcomesJson     String?
  outcomePricesJson String?
  volume           Float?            @default(0)
  liquidity        Float?            @default(0)

  lastSyncedAt     DateTime?
  canonicalGroupId String?

  snapshots        MarketSnapshot[]
  matches          MarketPostMatch[]
  tags             MarketTag[]

  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@unique([provider, providerMarketId])
  @@index([active, status, endDate])
  @@index([categoryId, active])
  @@index([provider, active, status])
  @@index([slug])
}

model MarketSnapshot {
  id           String   @id @default(cuid())
  marketId     String
  market       Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)

  yesProbability Float
  noProbability  Float
  volume         Float?
  liquidity      Float?

  fetchedAt     DateTime @default(now())

  @@index([marketId, fetchedAt])
}

model Post {
  id              String          @id @default(cuid())
  provider        String
  providerPostId  String
  sourceAccountId String
  sourceAccount   SourceAccount   @relation(fields: [sourceAccountId], references: [id], onDelete: Cascade)

  url            String
  text           String
  postedAt       DateTime

  replyCount     Int?             @default(0)
  repostCount    Int?             @default(0)
  likeCount      Int?             @default(0)
  quoteCount     Int?             @default(0)

  mediaJson      String?
  rawJson        String?

  matches        MarketPostMatch[]

  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@unique([provider, providerPostId])
  @@index([postedAt])
  @@index([sourceAccountId, postedAt])
}

model MarketPostMatch {
  id               String       @id @default(cuid())
  marketId         String
  postId           String

  market           Market       @relation(fields: [marketId], references: [id], onDelete: Cascade)
  post             Post         @relation(fields: [postId], references: [id], onDelete: Cascade)

  relevanceScore   Float        @default(0.0)
  stanceLabel      String?
  stanceConfidence Float?       @default(0.0)

  relevanceMethod  String?
  stanceMethod     String?
  rationaleSummary String?

  hidden           Boolean      @default(false)
  pinned           Boolean      @default(false)
  manualOverride   Boolean      @default(false)

  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@unique([marketId, postId])
  @@index([marketId])
  @@index([postId])
  @@index([pinned, hidden])
}

model JobRun {
  id           String     @id @default(cuid())
  jobType      String
  status       String     @default("PENDING")
  startedAt    DateTime   @default(now())
  finishedAt   DateTime?
  metadata     String?
  errorMessage String?

  @@index([jobType, startedAt])
  @@index([status])
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  eventType String
  payload   String
  createdAt DateTime @default(now())

  @@index([eventType, createdAt])
}

model MarketTag {
  id        String   @id @default(cuid())
  marketId  String
  label     String

  market    Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([marketId, label])
  @@index([marketId])
  @@index([label])
}
